import pandas as pd
import glob
import os
import numpy as np
from IPython.display import display

# ================= CONFIGURATION =================
# Adjust these paths if your notebook is in a different folder
GT_FILE_PATH = "Dataset/PHQ8 Mapping/GrouthTruth_PHQ8_Labels.csv"
PREDICTION_DIR = "single-agent-baseline/Analysis_Metrics" #Change Path here

# Mappings
GT_COLUMN_MAP = {
    "PHQ_8NoInterest": "I1", "PHQ_8Depressed": "I2", "PHQ_8Sleep": "I3",
    "PHQ_8Tired": "I4", "PHQ_8Appetite": "I5", "PHQ_8Failure": "I6",
    "PHQ_8Concentrating": "I7", "PHQ_8Moving": "I8"
}

ALIGNMENT_PAIRS = [
    # 1. Anhedonia (I1) overlaps with: Depressed(I2), Fatigue(I4), Concentration(I7), Psychomotor(I8)
    ("I1", "I2"), ("I1", "I4"), ("I1", "I7"), ("I1", "I8"),

    # 2. Depressed Mood (I2) overlaps with: Fatigue(I4), Concentration(I7), Psychomotor(I8)
    # (Note: I2-I1 is already covered above)
    ("I2", "I4"), ("I2", "I7"), ("I2", "I8"),

    # 3. Sleep (I3) overlaps with: Fatigue(I4), Concentration(I7), Psychomotor(I8)
    ("I3", "I4"), ("I3", "I7"), ("I3", "I8"),

    # 4. Fatigue (I4) overlaps with: Psychomotor(I8)
    # (Note: I4's links to I1, I2, I3 are covered above)
    ("I4", "I8"),

    # 5. Appetite (I5) overlaps with: Anhedonia(I1), Depressed(I2), Psychomotor(I8)
    ("I5", "I1"), ("I5", "I2"), ("I5", "I8"),

    # 6. Self-Esteem (I6) overlaps with: Anhedonia(I1), Depressed(I2), Psychomotor(I8)
    ("I6", "I1"), ("I6", "I2"), ("I6", "I8"),

    # 7. Concentration (I7) overlaps with: Fatigue(I4), Psychomotor(I8)
    # (Note: I7's links to I2, I3 are covered above)
    ("I7", "I4"), ("I7", "I8")
    
    # 8. Psychomotor (I8)
    # (All I8 connections are covered in the lines above)
]

# ================= 1. LOAD DATA =================

def load_data():
    # A. Load Ground Truth
    if not os.path.exists(GT_FILE_PATH):
        print(f"❌ Error: Ground Truth file not found at {GT_FILE_PATH}")
        return pd.DataFrame()

    gt_raw = pd.read_csv(GT_FILE_PATH)
    gt_lookup = {}
    
    # Convert GT CSV to Dictionary for fast lookup
    for _, row in gt_raw.iterrows():
        pid = str(row["Participant_ID"])
        scores = {}
        for col, item_id in GT_COLUMN_MAP.items():
            if col in row:
                scores[item_id] = int(row[col])
        gt_lookup[pid] = scores

    print(f"✅ Loaded Ground Truth for {len(gt_lookup)} participants.")

    # B. Load Agent Predictions
    csv_files = glob.glob(os.path.join(PREDICTION_DIR, "Analysis_*.csv"))
    if not csv_files:
        print(f"❌ Error: No analysis files found in {PREDICTION_DIR}")
        return pd.DataFrame()

    all_rows = []
    for f in csv_files:
        try:
            df = pd.read_csv(f)
            # Ensure PID is string for matching
            if "PID" in df.columns:
                pid = str(df.iloc[0]["PID"])
                patient_gt = gt_lookup.get(pid, {})
                
                # Add Ground Truth & Error calculation to every row
                for _, row in df.iterrows():
                    item_id = row["Item"]
                    row_data = row.to_dict()
                    
                    real_score = patient_gt.get(item_id)
                    row_data["Ground_Truth_Score"] = real_score
                    
                    if real_score is not None and "Agent_Score" in row:
                        row_data["Abs_Error"] = abs(row["Agent_Score"] - real_score)
                        row_data["Exact_Match"] = 1 if row["Agent_Score"] == real_score else 0
                    
                    all_rows.append(row_data)
        except Exception as e:
            print(f"Error reading {f}: {e}")

    return pd.DataFrame(all_rows)

# Run the Loader
df_master = load_data()

# Show first few rows to verify it worked
if not df_master.empty:
    print(f"\n✅ Successfully compiled {len(df_master)} total interaction rows.")
    display(df_master.head()) # Jupyter command to show pretty table
else:
    print("❌ No data to analyze.")

# ================= 2. CALCULATE METRICS =================

if not df_master.empty:
    print("\n" + "="*40)
    print("📊 THESIS METRICS REPORT")
    print("="*40)

# --- METRIC 1: MISSING DOMAIN RATE (Vagueness, Timeframe, Relevance) ---
    print("\n🔹 [1] MISSING DOMAIN RATE (Lower is Better)")
    # 1. Define exactly what rows you WANT to see
    EXPECTED_FLAWS = ["relevance", "vagueness", "timeframe"]

    # 2. Group by the 'Injected_Flaw' column
    flaw_stats = df_master.groupby("Injected_Flaw").apply(
        lambda x: pd.Series({
            "Total_Injected": len(x),
            "Failures_to_detect": len(x[x["Bot_Caught_Flaw"] == False]),
            "Miss_Rate_Percent": (len(x[x["Bot_Caught_Flaw"] == False]) / len(x)) * 100
        })
    )

    # 3. Force the table to include all expected flaws
    # This adds the missing rows and fills them with 0 if data isn't found
    flaw_stats = flaw_stats.reindex(EXPECTED_FLAWS, fill_value=0)

    # Optional: Make it look cleaner (integers for counts)
    flaw_stats["Total_Injected"] = flaw_stats["Total_Injected"].astype(int)
    flaw_stats["Failures_to_detect"] = flaw_stats["Failures_to_detect"].astype(int)

    display(flaw_stats)

    # --- METRIC 2: DIAGNOSTIC ACCURACY (vs Ground Truth) ---
    print("\n🔹 [2] DIAGNOSTIC ACCURACY (Bot vs Human Labels)")
    # Filter only rows that have Ground Truth
    acc_df = df_master.dropna(subset=["Ground_Truth_Score"])
    
    if not acc_df.empty:
        mae = acc_df["Abs_Error"].mean()
        accuracy = acc_df["Exact_Match"].mean() * 100
        
        print(f"👉 Mean Absolute Error (MAE): {mae:.2f} points (Target < 1.0)")
        print(f"👉 Exact Match Accuracy:      {accuracy:.1f}%")
        
        # Breakdown by Item
        print("\n   Error Rate by Item:")
        item_breakdown = acc_df.groupby("Item")[["Abs_Error", "Exact_Match"]].mean()
        item_breakdown["Exact_Match"] *= 100 # Convert to %
        display(item_breakdown)
    else:
        print("⚠️ No Ground Truth matches found (Check PIDs).")


    # --- METRIC 3: ALIGNMENT SCORE (Internal Consistency) ---
    print("\n🔹 [3] ALIGNMENT SCORE (Clinical Coherence)")
    
    alignment_scores = []
    pids = df_master["PID"].unique()
    
    for pid in pids:
        p_df = df_master[df_master["PID"] == pid]
        for item_a, item_b in ALIGNMENT_PAIRS:
            row_a = p_df[p_df["Item"] == item_a]
            row_b = p_df[p_df["Item"] == item_b]
            
            if not row_a.empty and not row_b.empty:
                score_a = int(row_a.iloc[0]["Agent_Score"])
                score_b = int(row_b.iloc[0]["Agent_Score"])
                
                # Formula: 1 - (|A - B| / 3)
                diff = abs(score_a - score_b)
                alignment = 1.0 - (diff / 3.0)
                alignment_scores.append(alignment)

    if alignment_scores:
        avg_align = np.mean(alignment_scores) * 100
        print(f"👉 GLOBAL ALIGNMENT SCORE: {avg_align:.1f}%")
    else:
        print("⚠️ Not enough data for alignment pairs.")
