# 2. SIMULATED CLIENT ANSWER (Updated for INTRO support)
def simulate_client_answer(
    item_id: str,
    item_index: int,
    item_label: str,
    hypothesis_text: str,
    question_text: str,
    client_profile: Dict[str, Any],
    llm: ChatOpenAI,
    is_followup: bool = False,
) -> str:
    """
    Generate a simulated client answer with DYNAMIC difficulty.
    It randomly selects a difficulty level based on defined weights.
    """
    # --- 1. DYNAMIC DIFFICULTY SELECTION ---
    DIFFICULTY_MODES = ["level1", "level2", "level3"]
    # Weights: 20% Direct, 50% Paraphrase, 30% Ambiguous
    WEIGHTS = [0.2, 0.5, 0.3] 
    
    selected_difficulty = random.choices(DIFFICULTY_MODES, weights=WEIGHTS, k=1)[0]

    if selected_difficulty == "level3":  # HARD / AMBIGUOUS
        diff_instruction = (
            "**Internal Monologue: You are feeling unsure or guarded.**\n"
            "- Be vague, indecisive, or non-committal.\n"
            "- Use words like 'maybe', 'sort of', 'sometimes', 'I guess'.\n"
            "- Do NOT give specific numbers or clear timeframes yet.\n"
            "- Force the interviewer to dig deeper."
        )
    elif selected_difficulty == "level2": # MEDIUM / PARAPHRASE
        diff_instruction = (
            "**Internal Monologue: You are speaking naturally.**\n"
            "- Do NOT use clinical terms.\n"
            "- Use metaphors, stories, or descriptions (e.g., 'I feel heavy' instead of 'depressed').\n"
            "- The meaning is there, but the interviewer has to listen closely."
        )
    else: # LEVEL 1 (EASY / DIRECT)
        diff_instruction = (
            "**Internal Monologue: You want to be understood clearly.**\n"
            "- Be helpful and explicit.\n"
            "- Directly answer the question with a clear frequency or duration."
        )

    # --- 2. EXTRACT PROFILE & STYLE (Restored) ---
    persona = client_profile.get("persona", {})
    interaction_style = persona.get("interaction_style", {})
    clinical_signals = (client_profile.get("clinical_signals", {}) or {}).get("symptoms", {})
    behavioral_features = client_profile.get("behavioral_features", {})

    style_label = interaction_style.get("style_label", "")
    style_scores = interaction_style.get("scores", {})
    style_features = interaction_style.get("features", {})
    style_evidence = interaction_style.get("evidence_quotes", []) or []

    # --- LOGIC FOR INTRO VS. CLINICAL ITEMS ---
    if item_id == "INTRO":
        # Intro Case: No symptom lookup needed
        symptom_key = "general_wellbeing"
        symptom_block = {}
        special_instruction = (
            "This is the Introduction. Ignore clinical symptoms. "
            "Just answer the greeting naturally based on your persona, "
            "interaction style, and current mood."
        )
    else:
        # Standard Case: Look up the specific symptom
        symptom_key = SYMPTOM_KEY_BY_ITEM_ID.get(item_id, "")
        symptom_block = clinical_signals.get(symptom_key, {}) if clinical_signals else {}
        
        present = symptom_block.get("present", "uncertain")
        severity_hint = symptom_block.get("severity_hint", "uncertain")
        symptom_quotes = symptom_block.get("evidence_quotes", []) or []
        
        special_instruction = (
            f"Ground the content in the clinical_signals for this symptom:\n"
            f"  - Symptom Status: {present}\n"
            f"  - Severity Hint: {severity_hint}\n"
            f"  - Evidence Quotes (Use as inspiration): {symptom_quotes}\n"
            f"  - Focus on the LAST TWO WEEKS."
        )

    # Construct the Profile Snippet (Safe for LLM context)
    profile_snippet = {
        "persona": {
            "demographics": persona.get("demographics", {}),
            "interaction_style": {
                "style_label": style_label,
                "scores": style_scores,
                "features": style_features,
                "evidence_quotes": style_evidence[:5],
            },
        },
        "clinical_signals": {
            "symptoms": {
                symptom_key: symptom_block
            }
        },
        "behavioral_features": behavioral_features,
    }

    role_tag = "follow-up" if is_followup else "initial"
    
    # --- FINAL PROMPT ---
    prompt = f"""
You are role-playing a client in a PHQ-8 style clinical intake interview.

Here is the *client profile* (JSON-like, do NOT quote it back directly):
{json.dumps(profile_snippet, ensure_ascii=False, indent=2)}

The interviewer just asked this {role_tag} question:
\"\"\"{question_text}\"\"\"

Instructions for your reply:
- Answer AS THIS CLIENT, in first person ("I").
- Keep your tone consistent with interaction_style.style_label.
- {special_instruction}
- Use a natural, conversational style.
- Length: 1–3 short sentences.
- Do NOT mention that you are a profile, a dataset, or an AI.

Now write ONLY the client's answer.
"""
    try:
        resp = llm.invoke(prompt)
        text = (getattr(resp, "content", "") or "").strip()
        return text if text else "..."
    except Exception as e:
        print(f"Simulation Error: {e}")
        return "I'm not sure."

