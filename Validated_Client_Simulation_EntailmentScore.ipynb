import pandas as pd
import glob
from pathlib import Path

# 1. Setup Path
# This matches the folder structure we created earlier
folder_path = Path("EntailmentScore(Profile)/Profile")

# 2. Find all score files (300_..., 301_..., etc.)
all_files = list(folder_path.glob("*_domain_scores.csv"))

print(f"📂 Found {len(all_files)} participant files: {[f.name for f in all_files]}")

if len(all_files) == 0:
    print("❌ No files found! Make sure you ran the Entailment script for the participants first.")
else:
    # 3. Loop through files and combine them
    df_list = []
    for filename in all_files:
        df = pd.read_csv(filename)
        # Extract ID from filename (e.g., "300") for tracking
        pid = filename.name.split('_')[0] 
        df['participant_id'] = pid
        df_list.append(df)

    # Combine into one big dataframe
    combined_df = pd.concat(df_list, ignore_index=True)

    # 4. Calculate Averages
    # We group by 'category' and calculate the mean of 'entailment_score'
    summary = combined_df.groupby("category").agg(
        final_average_score=("entailment_score", "mean"),
        total_claims_verified=("total_claims", "sum"),
        participants_count=("participant_id", "nunique") # How many people had this category
    ).reset_index().sort_values("final_average_score", ascending=False)

    # 5. Calculate the "Grand Average" (Total System Score)
    grand_average = summary["final_average_score"].mean()

    # 6. Display Output
    print("\n" + "="*40)
    print("   📊 AGGREGATED RESULTS (ALL PARTICIPANTS)")
    print("="*40)
    display(summary) # 'display' makes it look nice in Jupyter
    
    print("\n" + "-"*40)
    print(f"⭐ SYSTEM-WIDE GRAND AVERAGE: {grand_average:.4f}")
    print("-"*40)
